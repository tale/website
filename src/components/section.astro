---
interface Props {
	title: string;
	id?: string;
	level?: 2 | 3;
	class?: string;
}

const { title, id, level = 2, class: extra = "" } = Astro.props;
const Tag = `h${level}` as "h2" | "h3";
---

<Tag id={id} class={`mb-2 font-bold ${extra}`}>
	<span class="opacity-50">{level === 2 ? "##" : "###"}</span>
	{title}
</Tag>
