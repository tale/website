---
import { getCollection } from "astro:content";
const users = await getCollection("sponsorUsers");
const orgs = await getCollection("sponsorOrganizations");
const [totalBreakdown] = await getCollection("sponsorTotal");

if (totalBreakdown == null) {
	throw new Error("Missing sponsor total breakdown data");
}

const { total } = totalBreakdown.data;
---

<h2 class="font-bold">Sponsors</h2>
<p class="mt-1 text-sm opacity-60">
	Thank you to all active sponsors and {total} total all-time sponsors!
</p>

{
	users.length > 0 && (
		<div class="mt-3 flex flex-wrap gap-3">
			{users.map((sponsor) => (
				<a
					href={sponsor.data.url}
					target="_blank"
					rel="noopener noreferrer"
					class="group flex items-center gap-2 border border-neutral-300 p-2 hover:border-blue-400 dark:border-neutral-700 dark:hover:border-blue-500"
				>
					<img
						src={sponsor.data.avatar}
						alt={sponsor.data.name}
						width="32"
						height="32"
						class="rounded-full"
						loading="lazy"
					/>
					<span class="text-sm group-hover:underline">
						{sponsor.data.name}
					</span>
				</a>
			))}
		</div>
	)
}

{
	orgs.length > 0 && (
		<>
			<br />
			<h2 class="font-bold">Organizations</h2>
			<div class="mt-3 flex flex-wrap gap-3">
				{orgs.map((sponsor) => (
					<a
						href={sponsor.data.url}
						target="_blank"
						rel="noopener noreferrer"
						class="group flex items-center gap-2 border border-neutral-300 p-2 hover:border-blue-400 dark:border-neutral-700 dark:hover:border-blue-500"
					>
						<img
							src={sponsor.data.avatar}
							alt={sponsor.data.name}
							width="32"
							height="32"
							class="rounded-full"
							loading="lazy"
						/>
						<span class="text-sm group-hover:underline">
							{sponsor.data.name}
						</span>
					</a>
				))}
			</div>
		</>
	)
}
