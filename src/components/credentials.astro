---
import { getCollection } from "astro:content";
import Link from "@/components/link.astro";
import Section from "@/components/section.astro";
import { Icon } from "astro-icon/components";

const credentials = await getCollection("credentials");

const experiences = credentials
	.filter((item) => item.data.id.startsWith("exp:"))
	.map((item) => ({ ...item.data, id: item.data.id.replace("exp:", "") }))
	.sort((a, b) => {
		const aStart = Array.isArray(a.range) ? a.range[0] : a.range;
		const bStart = Array.isArray(b.range) ? b.range[0] : b.range;
		return bStart - aStart;
	});

const educations = credentials
	.filter((item) => item.data.id.startsWith("edu:"))
	.map((item) => ({ ...item.data, id: item.data.id.replace("edu:", "") }))
	.sort((a, b) => {
		const aStart = Array.isArray(a.range) ? a.range[0] : a.range;
		const bStart = Array.isArray(b.range) ? b.range[0] : b.range;
		return bStart - aStart;
	});
---

<Section title="Experience" meta={`[${experiences.length} entries]`} />
<table class="w-full border-collapse border border-neutral-300 dark:border-neutral-700">
	<colgroup>
		<col />
		<col class="w-[14ch]" />
	</colgroup>
	<thead>
		<tr class="border-b border-neutral-300 uppercase opacity-50 dark:border-neutral-700">
			<th class="border-r border-neutral-300 px-2 py-1 text-left font-bold dark:border-neutral-700">
				Role
			</th>
			<th class="px-2 py-1 text-right font-bold">Tenure</th>
		</tr>
	</thead>
	<tbody>
		{
			experiences.map((exp) => (
				<tr class="border-b border-neutral-300 last:border-b-0 hover:bg-neutral-200/60 dark:border-neutral-700 dark:hover:bg-neutral-700/40">
					<td class="border-r border-neutral-300 dark:border-neutral-700 px-2 py-1">
						<span class="flex flex-wrap items-center gap-2">
							<Icon
								name={exp.id}
								size={20}
								style={`background-color: ${exp.tint}`}
								class="inline-block"
							/>
							<span>
								{exp.role} @
								{exp.link ? (
									<Link external to={exp.link}>
										[{exp.org}]
									</Link>
								) : (
									exp.org
								)}
							</span>
						</span>
					</td>
					<td class="px-2 py-1 tabular-nums opacity-50 text-right whitespace-nowrap">
						{Array.isArray(exp.range)
							? `${exp.range[0]} -> ${exp.range[1] === -1 ? "...." : exp.range[1]}`
							: exp.range}
					</td>
				</tr>
			))
		}
	</tbody>
</table>

<Section title="Education" class="mt-6" meta={`[${educations.length} entries]`} />
<table class="w-full border-collapse border border-neutral-300 dark:border-neutral-700">
	<colgroup>
		<col />
		<col class="w-[14ch]" />
	</colgroup>
	<thead>
		<tr class="border-b border-neutral-300 uppercase opacity-50 dark:border-neutral-700">
			<th class="border-r border-neutral-300 px-2 py-1 text-left font-bold dark:border-neutral-700">
				Institution
			</th>
			<th class="px-2 py-1 text-right font-bold">Degree</th>
		</tr>
	</thead>
	<tbody>
		{
			educations.map((exp) => (
				<tr class="border-b border-neutral-300 last:border-b-0 hover:bg-neutral-200/60 dark:border-neutral-700 dark:hover:bg-neutral-700/40">
					<td class="border-r border-neutral-300 dark:border-neutral-700 px-2 py-1">
						<span class="flex items-center gap-2">
							<Icon
								name={exp.id}
								size={20}
								style={`background-color: ${exp.tint}`}
								class="inline-block"
							/>
							{exp.abbr ? (
								<>
									<span class="hidden sm:inline">{exp.org}</span>
									<span class="sm:hidden">{exp.abbr}</span>
								</>
							) : (
								<span>{exp.org}</span>
							)}
						</span>
					</td>
					<td class="px-2 py-1 tabular-nums opacity-50 text-right whitespace-nowrap">
						{exp.role}
					</td>
				</tr>
			))
		}
	</tbody>
</table>
