---
import { getCollection, render } from "astro:content";
import Link from "@/components/link.astro";
import Section from "@/components/section.astro";
import Site from "@/layouts/site.astro";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const imageUrl = new URL(`/assets/${post.id}.png`, Astro.url);

const pad = (n: number) => n.toString().padStart(2, "0");
const isoDate = `${post.data.date.getUTCFullYear()}-${pad(
	post.data.date.getUTCMonth() + 1,
)}-${pad(post.data.date.getUTCDate())}`;

const tableOfContents = headings
	.filter((heading) => heading.depth <= 3)
	.map((heading) => ({
		text: heading.text,
		depth: heading.depth,
		href: `#${heading.slug}`,
	}));
---

<Fragment slot="head">
	<meta property="og:url" content={Astro.url.href} />
	<meta property="og:type" content="article" />
	<meta property="og:title" content={post.data.title} />
	<meta property="og:description" content={post.data.description} />
	<meta property="og:image" content={imageUrl.href} />

	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:site" content="@aarnavtale" />
	<meta name="twitter:creator" content="@aarnavtale" />
	<meta name="twitter:title" content={post.data.title} />
	<meta name="twitter:description" content={post.data.description} />
	<meta name="twitter:image" content={imageUrl.href} />
</Fragment>

<Site title={post.data.title} desc={post.data.description}>
	{
		tableOfContents.length > 0 && (
			<aside class="fixed top-32 right-8 hidden max-h-[70vh] w-64 overflow-y-auto border-l border-neutral-300 pl-4 xl:block dark:border-neutral-700">
				<Section level={3} title="On This Page" />
				<ul class="space-y-1">
					{tableOfContents.map((item) => (
						<li
							class={
								item.depth === 3 ? "pl-4 opacity-80" : ""
							}
						>
							<a href={item.href} class="hover:underline">
								<span class="opacity-50">-</span> {item.text}
							</a>
						</li>
					))}
				</ul>
			</aside>
		)
	}

	<p class="mb-3"><Link to="/">[&lt;- back to index]</Link></p>
	<table
		class="mb-6 w-full border-collapse border border-neutral-300 dark:border-neutral-700"
	>
		<tbody>
			<tr class="border-b border-neutral-300 dark:border-neutral-700">
				<th
					class="border-r border-neutral-300 px-2 py-1 text-left align-top font-bold uppercase whitespace-nowrap opacity-50 dark:border-neutral-700"
				>
					Title
				</th>
				<td class="px-2 py-1 font-bold uppercase">
					{post.data.title}
				</td>
			</tr>
			{
				post.data.description && (
					<tr class="border-b border-neutral-300 dark:border-neutral-700">
						<th class="border-r border-neutral-300 px-2 py-1 text-left align-top font-bold uppercase whitespace-nowrap opacity-50 dark:border-neutral-700">
							Description
						</th>
						<td class="px-2 py-1">{post.data.description}</td>
					</tr>
				)
			}
			<tr>
				<th
					class="border-r border-neutral-300 px-2 py-1 text-left align-top font-bold uppercase whitespace-nowrap opacity-50 dark:border-neutral-700"
				>
					Published
				</th>
				<td class="px-2 py-1 tabular-nums">{isoDate}</td>
			</tr>
		</tbody>
	</table>

	{
		tableOfContents.length > 0 && (
			<details class="mb-6 border border-neutral-300 p-3 xl:hidden dark:border-neutral-700">
				<summary
					class="cursor-pointer font-bold uppercase select-none"
				>
					On This Page
				</summary>
				<ul class="mt-2 space-y-1">
					{tableOfContents.map((item) => (
						<li
							class={
								item.depth === 3 ? "pl-4 opacity-80" : ""
							}
						>
							<a href={item.href} class="hover:underline">
								<span class="opacity-50">-</span> {item.text}
							</a>
						</li>
					))}
				</ul>
			</details>
		)
	}

	<div
		class={`
			prose prose-md dark:prose-invert prose-md
			prose-img:rounded-none prose-img:shadow-lg prose-img:mx-auto
			prose-video:rounded-none prose-video:shadow-md prose-video:mx-auto
			prose-figcaption:mt-2 prose-figcaption:text-center
			prose-blockquote:font-normal prose-pre:font-normal max-w-3xl
			prose-p:leading-relaxed
			prose-p:text-neutral-600 dark:prose-p:text-neutral-400
			prose-li:text-neutral-600 dark:prose-li:text-neutral-400
			prose-blockquote:text-neutral-600 dark:prose-blockquote:text-neutral-400
			prose-figcaption:text-neutral-600 dark:prose-figcaption:text-neutral-400
			prose-strong:font-normal
			prose-strong:text-neutral-900 dark:prose-strong:text-neutral-50
			prose-headings:text-base prose-headings:font-bold
			prose-headings:uppercase
			prose-headings:text-neutral-900 dark:prose-headings:text-neutral-50
			prose-h2:mt-8 prose-h2:mb-2 prose-h3:mt-6 prose-h3:mb-2
			prose-hr:opacity-30
		`}
	>
		<Content />
	</div>
</Site>
