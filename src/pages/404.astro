---
import Link from "@/components/link.astro";
import Site from "@/layouts/site.astro";
---

<Site title="404 Not Found" desc="The page you are looking for does not exist">
	<p class="mb-4">
		The requested resource could not be located on this server. The URL may
		be mistyped, or the page may have been moved or removed.
	</p>
	<p>
		<Link to="/">[head home]</Link>
	</p>
</Site>
