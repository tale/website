    "@iconify-json/logos": "^1.2.11",
    "@microflash/rehype-figure": "^2.1.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "7.0.0-alpha.1",
    "astro-icon": "^1.1.5",
    "astro-meta-tags": "^0.4.1",
    "github-slugger": "^2.0.0",
    "satori": "^0.26.0",
